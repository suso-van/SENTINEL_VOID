
# --- PROJECT SETTINGS ---
PROJECT_NAME="AI-Qdrant-Engine"

# --- QDRANT CONFIGURATION ---
# If running via Docker on the same machine, use 'localhost'
# If running inside a Docker network, you would use the service name
QDRANT_HOST="localhost"
QDRANT_PORT=6333
COLLECTION_NAME="ai_knowledge_base"
VECTOR_SIZE=384

# --- LLM PROVIDER CONFIGURATION ---
# Choose one and fill in your API key
OPENAI_API_KEY="your_openai_api_key_here"

# Optional: If you want to use Groq (highly recommended for speed/free tier)
GROQ_API_KEY="your_groq_api_key_here"

# --- SERVER SETTINGS ---
# Set to 'development' or 'production'
ENV_MODE="development"